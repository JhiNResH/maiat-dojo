generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Users ---
model User {
  id            String    @id @default(cuid())
  privyId       String?   @unique
  email         String?   @unique
  walletAddress String?   @unique
  displayName   String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // --- KYA (Know Your Agent) — 2026-04-05 ---
  erc8004TokenId      BigInt?   @unique      // KYA-0 eager mint
  kyaLevel            Int       @default(0)  // 0, 1, 2 (3 deferred to Phase 2+)
  socialHandleType    String?                // 'twitter' | 'github'
  socialHandle        String?   @unique
  socialVerifiedAt    DateTime?
  veteranWallet       String?   @unique
  veteranVerifiedAt   DateTime?
  pendingMint         Boolean   @default(false)

  // --- API access (Phase 1 REST API) ---
  apiKey        String?   @unique   // dojo_sk_xxx — used for /api/v1/* endpoints
  creditBalance Float     @default(0) // USDC credits for pay-per-call

  // Relations
  reviews       Review[]
  purchases     Purchase[]
  createdSkills Skill[]    @relation("SkillCreator")
  createdWorkflows Workflow[] @relation("WorkflowCreator")
  createdForks WorkflowFork[] @relation("ForkCreator")
  createdRunReceipts WorkflowRunReceipt[] @relation("ReceiptCreator")
  ownedAgents   Agent[]    @relation("AgentOwner")
}

// --- Skills ---
model Skill {
  id          String   @id @default(cuid())
  onChainId   Int?     @unique  // maps to SkillNFT skillId on-chain
  name        String
  description String
  longDescription String?
  category    String
  icon        String   @default("⚡")
  price       Float    @default(0)
  currency    String   @default("USD")
  rating      Float    @default(0)
  installs    Int      @default(0)
  tags        String   @default("") // comma-separated
  imageUrl    String?
  skillUrl    String?  // hosted SKILL.md URL (GitHub raw, IPFS, etc.)
  fileContent String?  // inline SKILL.md content (v1 seed fallback)
  fileType    String?  // "markdown" | "json" | "text"
  isGated     Boolean  @default(true)  // require purchase to access content
  evaluationScore  Float?    // micro evaluator score (0-100)
  evaluationPassed Boolean?  // whether skill passed evaluation
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // --- Active skill / Gateway fields — 2026-04-05 ---
  skillType               String   @default("passive")  // passive | active
  endpointUrl             String?                        // creator's raw endpoint (active only)
  gatewaySlug             String?  @unique               // dojo.maiat.io/skills/{slug}
  creatorHmacSecret       String?                        // gateway→creator auth
  pricePerCall            Float?                         // active skill per-call price (USDC)
  expectedCallsPerSession Int?                           // rate-limit cap basis

  // --- Profile-driven renderer fields — 2026-04-09 ---
  // See: specs/2026-04-09-chat-first-ui.md
  // SQLite has no Json type → JSON stored as String, parsed at runtime via lib/skill-profile.ts
  executionKind     String   @default("sync")    // sync | async | stream | download | stateful | hitl
  inputShape        String   @default("form")    // form | file | custom
  outputShape       String   @default("json")    // json | text | image | audio | file | html | stream
  estLatencyMs      Int      @default(2000)
  sandboxable       Boolean  @default(true)
  authRequired      Boolean  @default(false)
  inputSchema       String?                       // JSON Schema (stringified)
  outputSchema      String?                       // JSON Schema (stringified)
  exampleInput      String?                       // example object (stringified)
  exampleOutput     String?                       // example object (stringified)
  mcpManifest       String?                       // Phase 3: MCP tool descriptor (stringified)
  customRendererUrl String?                       // Phase 3: iframe URL

  // Creator
  creatorId   String
  creator     User     @relation("SkillCreator", fields: [creatorId], references: [id])

  // Relations
  reviews     Review[]
  purchases   Purchase[]
  equippedBy  AgentSkill[]
  sessions    Session[]
  workflow    Workflow?
}

// --- Agents ---
model Agent {
  id             String   @id @default(cuid())
  name           String
  description    String
  avatar         String   @default("🤖")
  rank           String   @default("Kozo 小僧")
  xp             Int      @default(0)
  jobsCompleted  Int      @default(0)
  successRate    Float    @default(0)
  totalEarnings  Float    @default(0)
  earningsCurrency String @default("ETH")
  walletAddress  String?  @unique
  tbaAddress     String?  // ERC-6551 Token Bound Account address
  trustScore     Float?   // computed trust score (0-100)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Owner
  ownerId        String
  owner          User     @relation("AgentOwner", fields: [ownerId], references: [id])

  // Relations
  skills         AgentSkill[]
  reviews        Review[]
  jobs           Job[]
  sessions       Session[]
  workflowRunReceipts WorkflowRunReceipt[] @relation("ReceiptBuyerAgent")
}

// --- Agent <-> Skill (equipped) ---
model AgentSkill {
  id        String   @id @default(cuid())
  agentId   String
  skillId   String
  equippedAt DateTime @default(now())

  agent     Agent    @relation(fields: [agentId], references: [id])
  skill     Skill    @relation(fields: [skillId], references: [id])

  @@unique([agentId, skillId])
}

// --- Reviews ---
model Review {
  id         String   @id @default(cuid())
  rating     Int      // 1-5
  comment    String
  createdAt  DateTime @default(now())

  // Reviewer
  userId     String
  user       User     @relation(fields: [userId], references: [id])

  // Target (skill or agent)
  skillId    String?
  skill      Skill?   @relation(fields: [skillId], references: [id])
  agentId    String?
  agent      Agent?   @relation(fields: [agentId], references: [id])

  // Receipt gate — one review per session per skill
  sessionId  String?
  session    Session? @relation(fields: [sessionId], references: [id])

  @@unique([userId, skillId, sessionId])
}

// --- Purchases ---
model Purchase {
  id             String   @id @default(cuid())
  amount         Float
  currency       String   @default("USD")
  status         String   @default("completed") // pending, completed, refunded
  txHash         String?  // on-chain tx if crypto
  stripeId       String?  // stripe payment intent
  attestationUid String?  // EAS attestation UID
  onchainJobId   String?  // ERC-8183 job ID on X Layer
  createdAt      DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  skillId    String
  skill      Skill    @relation(fields: [skillId], references: [id])
}

// --- Jobs ---
model Job {
  id          String   @id @default(cuid())
  title       String
  description String
  status      String   @default("open") // open, in-progress, completed, rejected
  payment     Float    @default(0)
  currency    String   @default("USD")
  rating      Int?     // 1-5 buyer rating
  completedAt DateTime?
  createdAt   DateTime @default(now())

  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id])
}

// --- Sessions (8183 job with pre-funded escrow) — 2026-04-05 ---
// Agent opens a session to pre-fund escrow, then makes per-call skill invocations
// against it via Gateway. Settled via MicroEvaluator when escrow used/expires.
model Session {
  id               String   @id @default(cuid())
  onchainJobId     String?  @unique             // ERC-8183 jobId on Base
  budgetTotal      Float                        // initial escrow (USDC)
  budgetRemaining  Float                        // decrements per call
  pricePerCall     Float                        // snapshot at open time
  callCount        Int      @default(0)
  status           String   @default("funded")  // funded | active | autocompleting | settled | refunded
  openedAt         DateTime @default(now())
  expiresAt        DateTime                     // default now + 24h
  settledAt        DateTime?

  // payer = agent (has wallet, is 8183 payer)
  payerAgentId     String
  agent            Agent    @relation(fields: [payerAgentId], references: [id])

  // target skill
  skillId          String
  skill            Skill    @relation(fields: [skillId], references: [id])

  basAttestationUid String?  // BAS attestation UID emitted at session close

  // Relations
  calls            SkillCall[]
  reviews          Review[]
  workflowRunReceipts WorkflowRunReceipt[]

  @@index([status, expiresAt])
  @@index([payerAgentId])
  @@index([payerAgentId, status])
  @@index([skillId])
}

// --- SkillCall (per-call log, Gateway writes) — 2026-04-05 ---
model SkillCall {
  id           String   @id @default(cuid())
  sessionId    String
  nonce        Int                    // monotonic per (agent, session)
  requestHash  String                 // X-Dojo-RequestHash
  status       String                 // success | creator_error | gateway_error
  httpStatus   Int
  latencyMs    Int?
  costUsdc     Float                  // = session.pricePerCall at time of call
  createdAt    DateTime @default(now())

  // --- Sanity-check evaluator fields — 2026-04-07 ---
  responseHash String?                // keccak256(responseBody); null on gateway_error
  delivered    Boolean  @default(false) // httpStatus 2xx AND response received
  validFormat  Boolean  @default(false) // response body is valid JSON
  withinSla    Boolean  @default(false) // latencyMs < 5000
  score        Float    @default(0)    // 0.0 = fail | 1.0 = pass

  session      Session  @relation(fields: [sessionId], references: [id])
  workflowReceipt WorkflowRunReceipt?

  @@index([sessionId, nonce])
  @@unique([sessionId, nonce])
}

// --- Workflows (versioned agent processes) — 2026-04-27 ---
// Current Skills are one-step workflows. This layer adds run/fork/deploy
// semantics without breaking the existing /api/v1/run skill gateway.
model Workflow {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  category    String
  icon        String   @default("⚙️")
  status      String   @default("published") // draft | published | archived
  pricePerRun Float    @default(0)
  royaltyBps  Int      @default(500)
  runCount    Int      @default(0)
  forkCount   Int      @default(0)
  trustScore  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Optional one-step execution target. Multi-step workflows can leave this
  // null until the workflow runner exists.
  skillId     String?  @unique
  skill       Skill?   @relation(fields: [skillId], references: [id])

  creatorId   String
  creator     User     @relation("WorkflowCreator", fields: [creatorId], references: [id])

  versions      WorkflowVersion[]
  receipts      WorkflowRunReceipt[]
  forksAsParent WorkflowFork[] @relation("WorkflowForkParent")
  forksAsChild  WorkflowFork[] @relation("WorkflowForkChild")

  @@index([status, category])
  @@index([creatorId])
}

model WorkflowVersion {
  id              String   @id @default(cuid())
  workflowId      String
  version         Int      @default(1)
  title           String
  summary         String
  inputSchema     String?
  outputSchema    String?
  stepGraph       String
  evaluatorPolicy String
  slaMs           Int      @default(5000)
  createdAt       DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id])
  receipts WorkflowRunReceipt[]

  @@unique([workflowId, version])
  @@index([workflowId])
}

model WorkflowFork {
  id               String   @id @default(cuid())
  parentWorkflowId String
  childWorkflowId  String   @unique
  creatorId        String
  royaltyBps       Int      @default(500)
  createdAt        DateTime @default(now())

  parentWorkflow Workflow @relation("WorkflowForkParent", fields: [parentWorkflowId], references: [id])
  childWorkflow  Workflow @relation("WorkflowForkChild", fields: [childWorkflowId], references: [id])
  creator        User     @relation("ForkCreator", fields: [creatorId], references: [id])

  @@index([parentWorkflowId])
  @@index([creatorId])
}

model WorkflowRunReceipt {
  id               String   @id @default(cuid())
  workflowId       String
  versionId        String?
  skillCallId      String?  @unique
  sessionId        String
  buyerAgentId     String
  creatorId        String
  evaluator        String   @default("dojo-sanity-v1")
  requestHash      String
  responseHash     String?
  delivered        Boolean  @default(false)
  validFormat      Boolean  @default(false)
  withinSla        Boolean  @default(false)
  score            Float    @default(0)
  costUsdc         Float    @default(0)
  settlementStatus String   @default("paid") // paid | refunded | disputed
  attestationUid   String?
  createdAt        DateTime @default(now())

  workflow   Workflow         @relation(fields: [workflowId], references: [id])
  version    WorkflowVersion? @relation(fields: [versionId], references: [id])
  skillCall  SkillCall?       @relation(fields: [skillCallId], references: [id])
  session    Session          @relation(fields: [sessionId], references: [id])
  buyerAgent Agent            @relation("ReceiptBuyerAgent", fields: [buyerAgentId], references: [id])
  creator    User             @relation("ReceiptCreator", fields: [creatorId], references: [id])

  @@index([workflowId, createdAt])
  @@index([buyerAgentId, createdAt])
  @@index([creatorId, createdAt])
  @@index([sessionId])
}
